<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="digit_hist">digit_hist</variable>
    <variable id="even_cnt">even_cnt</variable>
    <variable id="odd_cnt">odd_cnt</variable>
    <variable id="over_cnt">over_cnt</variable>
    <variable id="under_cnt">under_cnt</variable>
    <variable id="counts">counts</variable>
    <variable id="item">item</variable>
    <variable id="i">i</variable>
    <variable id="max_val">max_val</variable>
    <variable id="min_val">min_val</variable>
    <variable id="most_app">most_app</variable>
    <variable id="least_app">least_app</variable>
    <variable id="text_even">text_even</variable>
    <variable id="text_over">text_over</variable>
    <variable id="text_extreme">text_extreme</variable>
  </variables>
  <block type="trade_definition" id="trade_def" x="0" y="0">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="market_def">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ10V</field>
        <next>
          <block type="trade_definition_tradetype" id="trade_type">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">matchesdiffers</field>
            <next>
              <block type="trade_definition_contracttype" id="contract_type">
                <field name="TYPE_LIST">both</field>
                <next>
                  <block type="trade_definition_candleinterval" id="candle_int">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="restart_def">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="onerror">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
    <statement name="INITIALIZATION">
      <block type="variables_set" id="init_hist">
        <field name="VAR" id="digit_hist">digit_hist</field>
        <value name="VALUE">
          <block type="lists_create_with" id="list_create">
            <mutation items="0"></mutation>
          </block>
        </value>
      </block>
    </statement>
    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="options">
        <mutation has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <field name="CURRENCY_LIST">USD</field>
        <value name="DURATION"><block type="math_number"><field name="NUM">1</field></block></value>
        <value name="AMOUNT"><block type="math_number"><field name="NUM">0.35</field></block></value>
        <value name="PREDICTION"><block type="math_number"><field name="NUM">0</field></block></value>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="before_pur" x="0" y="500">
    <statement name="BEFOREPURCHASE_STACK">
      <!-- Insert Last Digit -->
      <block type="lists_setIndex" id="insert_digit">
        <mutation at="false"></mutation>
        <field name="MODE">INSERT</field>
        <field name="WHERE">FIRST</field>
        <value name="LIST"><block type="variables_get"><field name="VAR" id="digit_hist">digit_hist</field></block></value>
        <value name="TO"><block type="last_digit"></block></value>
        <next>
          <!-- Limit list to 25 -->
          <block type="controls_if" id="limit_if">
            <value name="IF0"><block type="logic_compare"><field name="OP">GT</field><value name="A"><block type="lists_length"><value name="VALUE"><block type="variables_get"><field name="VAR" id="digit_hist">digit_hist</field></block></value></block></value><value name="B"><block type="math_number"><field name="NUM">25</field></block></value></block></value>
            <statement name="DO0">
              <block type="lists_getIndex" id="del_last">
                <mutation statement="true" at="false"></mutation>
                <field name="MODE">REMOVE</field>
                <field name="WHERE">LAST</field>
                <value name="VALUE"><block type="variables_get"><field name="VAR" id="digit_hist">digit_hist</field></block></value>
              </block>
            </statement>
            <next>

              <!-- Only process if array is full enough to matter! -->
              <block type="controls_if" id="process_if">
               <value name="IF0"><block type="logic_compare"><field name="OP">EQ</field><value name="A"><block type="lists_length"><value name="VALUE"><block type="variables_get"><field name="VAR" id="digit_hist">digit_hist</field></block></value></block></value><value name="B"><block type="math_number"><field name="NUM">25</field></block></value></block></value>
               <statement name="DO0">

                <!-- Reset values -->
                <block type="variables_set"><field name="VAR" id="even_cnt">even_cnt</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                <next><block type="variables_set"><field name="VAR" id="odd_cnt">odd_cnt</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                <next><block type="variables_set"><field name="VAR" id="under_cnt">under_cnt</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                <next><block type="variables_set"><field name="VAR" id="over_cnt">over_cnt</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                <next><block type="variables_set"><field name="VAR" id="counts">counts</field>
                  <value name="VALUE">
                    <block type="lists_create_with">
                        <mutation items="10"></mutation>
                        <value name="ADD0"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD1"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD2"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD3"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD4"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD5"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD6"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD7"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD8"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="ADD9"><block type="math_number"><field name="NUM">0</field></block></value>
                    </block>
                  </value>
                <next>

                  <!-- Iterate history -->
                  <block type="controls_forEach" id="loop1">
                    <field name="VAR" id="item">item</field>
                    <value name="LIST"><block type="variables_get"><field name="VAR" id="digit_hist">digit_hist</field></block></value>
                    <statement name="DO">
                      <!-- Even/Odd Count -->
                      <block type="controls_if" id="eo_if"><mutation else="1"></mutation>
                        <value name="IF0"><block type="math_number_property"><mutation divisor_input="false"></mutation><field name="PROPERTY">EVEN</field><value name="NUMBER_TO_CHECK"><block type="variables_get"><field name="VAR" id="item">item</field></block></value></block></value>
                        <statement name="DO0"><block type="math_change"><field name="VAR" id="even_cnt">even_cnt</field><value name="DELTA"><block type="math_number"><field name="NUM">1</field></block></value></block></statement>
                        <statement name="ELSE"><block type="math_change"><field name="VAR" id="odd_cnt">odd_cnt</field><value name="DELTA"><block type="math_number"><field name="NUM">1</field></block></value></block></statement>
                        <next>
                          <!-- Over/Under Count -->
                          <block type="controls_if" id="ou_if"><mutation else="1"></mutation>
                            <value name="IF0"><block type="logic_compare"><field name="OP">GTE</field><value name="A"><block type="variables_get"><field name="VAR" id="item">item</field></block></value><value name="B"><block type="math_number"><field name="NUM">5</field></block></value></block></value>
                            <statement name="DO0"><block type="math_change"><field name="VAR" id="over_cnt">over_cnt</field><value name="DELTA"><block type="math_number"><field name="NUM">1</field></block></value></block></statement>
                            <statement name="ELSE"><block type="math_change"><field name="VAR" id="under_cnt">under_cnt</field><value name="DELTA"><block type="math_number"><field name="NUM">1</field></block></value></block></statement>
                            <next>
                              <!-- Counts Array Update -->
                              <block type="lists_setIndex" id="upd_counts">
                                <mutation at="true"></mutation>
                                <field name="MODE">SET</field>
                                <field name="WHERE">FROM_START</field>
                                <value name="LIST"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value>
                                <value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="item">item</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value>
                                <value name="TO"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="lists_getIndex"><mutation statement="false" at="true"></mutation><field name="MODE">GET</field><field name="WHERE">FROM_START</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value><value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="item">item</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>

                      <!-- Find Max and Min -->
                      <block type="variables_set"><field name="VAR" id="max_val">max_val</field><value name="VALUE"><block type="math_number"><field name="NUM">-1</field></block></value>
                      <next><block type="variables_set"><field name="VAR" id="min_val">min_val</field><value name="VALUE"><block type="math_number"><field name="NUM">100</field></block></value>
                      <next><block type="variables_set"><field name="VAR" id="most_app">most_app</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                      <next><block type="variables_set"><field name="VAR" id="least_app">least_app</field><value name="VALUE"><block type="math_number"><field name="NUM">0</field></block></value>
                      <next><block type="controls_for" id="loop2">
                        <field name="VAR" id="i">i</field>
                        <value name="FROM"><block type="math_number"><field name="NUM">0</field></block></value>
                        <value name="TO"><block type="math_number"><field name="NUM">9</field></block></value>
                        <value name="BY"><block type="math_number"><field name="NUM">1</field></block></value>
                        <statement name="DO">
                          <block type="controls_if" id="max_if">
                            <value name="IF0"><block type="logic_compare"><field name="OP">GT</field><value name="A"><block type="lists_getIndex"><mutation statement="false" at="true"></mutation><field name="MODE">GET</field><field name="WHERE">FROM_START</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value><value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="i">i</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value></block></value><value name="B"><block type="variables_get"><field name="VAR" id="max_val">max_val</field></block></value></block></value>
                            <statement name="DO0">
                              <block type="variables_set"><field name="VAR" id="max_val">max_val</field><value name="VALUE"><block type="lists_getIndex"><mutation statement="false" at="true"></mutation><field name="MODE">GET</field><field name="WHERE">FROM_START</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value><value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="i">i</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value></block></value>
                              <next><block type="variables_set"><field name="VAR" id="most_app">most_app</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="i">i</field></block></value></block></next></block>
                            </statement>
                            <next>
                              <block type="controls_if" id="min_if">
                                <value name="IF0"><block type="logic_compare"><field name="OP">LT</field><value name="A"><block type="lists_getIndex"><mutation statement="false" at="true"></mutation><field name="MODE">GET</field><field name="WHERE">FROM_START</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value><value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="i">i</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value></block></value><value name="B"><block type="variables_get"><field name="VAR" id="min_val">min_val</field></block></value></block></value>
                                <statement name="DO0">
                                  <block type="variables_set"><field name="VAR" id="min_val">min_val</field><value name="VALUE"><block type="lists_getIndex"><mutation statement="false" at="true"></mutation><field name="MODE">GET</field><field name="WHERE">FROM_START</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="counts">counts</field></block></value><value name="AT"><block type="math_arithmetic"><field name="OP">ADD</field><value name="A"><block type="variables_get"><field name="VAR" id="i">i</field></block></value><value name="B"><block type="math_number"><field name="NUM">1</field></block></value></block></value></block></value>
                                  <next><block type="variables_set"><field name="VAR" id="least_app">least_app</field><value name="VALUE"><block type="variables_get"><field name="VAR" id="i">i</field></block></value></block></next></block>
                                </statement>
                              </block>
                            </next>
                          </block>
                        </statement>
                        <next>

                          <!-- Calculate Texts -->
                          <block type="variables_set"><field name="VAR" id="text_even">text_even</field><value name="VALUE"><block type="text_join"><mutation items="6"></mutation><value name="ADD0"><block type="text"><field name="TEXT">📊 EVEN: </field></block></value><value name="ADD1"><block type="math_arithmetic"><field name="OP">MULTIPLY</field><value name="A"><block type="variables_get"><field name="VAR" id="even_cnt">even_cnt</field></block></value><value name="B"><block type="math_number"><field name="NUM">4</field></block></value></block></value><value name="ADD2"><block type="text"><field name="TEXT">% | ODD: </field></block></value><value name="ADD3"><block type="math_arithmetic"><field name="OP">MULTIPLY</field><value name="A"><block type="variables_get"><field name="VAR" id="odd_cnt">odd_cnt</field></block></value><value name="B"><block type="math_number"><field name="NUM">4</field></block></value></block></value><value name="ADD4"><block type="text"><field name="TEXT">% </field></block></value></block></value>
                          <next><block type="variables_set"><field name="VAR" id="text_over">text_over</field><value name="VALUE"><block type="text_join"><mutation items="6"></mutation><value name="ADD0"><block type="text"><field name="TEXT">📈 OVER(5-9): </field></block></value><value name="ADD1"><block type="math_arithmetic"><field name="OP">MULTIPLY</field><value name="A"><block type="variables_get"><field name="VAR" id="over_cnt">over_cnt</field></block></value><value name="B"><block type="math_number"><field name="NUM">4</field></block></value></block></value><value name="ADD2"><block type="text"><field name="TEXT">% | UNDER(0-4): </field></block></value><value name="ADD3"><block type="math_arithmetic"><field name="OP">MULTIPLY</field><value name="A"><block type="variables_get"><field name="VAR" id="under_cnt">under_cnt</field></block></value><value name="B"><block type="math_number"><field name="NUM">4</field></block></value></block></value><value name="ADD4"><block type="text"><field name="TEXT">% </field></block></value></block></value>
                          <next><block type="variables_set"><field name="VAR" id="text_extreme">text_extreme</field><value name="VALUE"><block type="text_join"><mutation items="6"></mutation><value name="ADD0"><block type="text"><field name="TEXT">🔥 HOTTEST = </field></block></value><value name="ADD1"><block type="variables_get"><field name="VAR" id="most_app">most_app</field></block></value><value name="ADD2"><block type="text"><field name="TEXT"> | 🧊 COLDEST = </field></block></value><value name="ADD3"><block type="variables_get"><field name="VAR" id="least_app">least_app</field></block></value></block></value>

                           <next>
                             <block type="notify">
                               <field name="NOTIFICATION_TYPE">info</field>
                               <field name="NOTIFICATION_SOUND">silent</field>
                               <value name="MESSAGE">
                                 <block type="text_join">
                                   <mutation items="4"></mutation>
                                   <value name="ADD0"><block type="text"><field name="TEXT">📊 [ANALYSIS] </field></block></value>
                                   <value name="ADD1"><block type="variables_get"><field name="VAR" id="text_even">text_even</field></block></value>
                                   <value name="ADD2"><block type="variables_get"><field name="VAR" id="text_over">text_over</field></block></value>
                                   <value name="ADD3"><block type="variables_get"><field name="VAR" id="text_extreme">text_extreme</field></block></value>
                                 </block>
                               </value>
                             </block>
                           </next>
                          </block></next></block></next></block></next></block></next></block>

                        </next>
                      </block></next></block></next></block></next></block></next></block>

                    </next>
                  </block>

                </next>
                </block></next></block></next></block></next></block></next></block>

               </statement>
              </block>

            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <!-- Dummy After Purchase block is technically needed for validation for standard engines but we won't hit it unless you add a purchase block -->
  <block type="after_purchase" id="after_pur" x="0" y="1000">
    <statement name="AFTERPURCHASE_STACK">
      <block type="trade_again"></block>
    </statement>
  </block>
</xml>
